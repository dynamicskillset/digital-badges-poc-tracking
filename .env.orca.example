# ORCA Environment Template
# Copy to .env.orca and fill in the bracketed placeholders before first
# start. The real .env.orca is listed in .gitignore next to
# .env.transaction / .env.signing / .env.postgres.

# ─────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────
# Default: in-compose postgres (defined in docker-compose.yml +
# .env.postgres). User/password/db must match POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB. Schema `orca_public` is created in
# postgres/init/01-orca-db-and-schemas.sql — use ?schema=orca_public,
# not public.
DATABASE_SERVERLESS="false"
DATABASE_URL="postgresql://orcaadmin:REPLACE_WITH_A_STRONG_SECRET@postgres:5432/orca?schema=orca_public"
DATABASE_URL_DIRECT="postgresql://orcaadmin:REPLACE_WITH_A_STRONG_SECRET@postgres:5432/orca?schema=orca_public"

# Alternative: hosted Neon serverless. Comment the in-compose block
# above and uncomment below. DATABASE_URL_DIRECT must be the
# non-pooled Neon endpoint so prisma migrate deploy can connect.
# DATABASE_SERVERLESS="true"
# DATABASE_URL="postgresql://<user>:<pw>@<pooled-endpoint>/<db>?sslmode=require"
# DATABASE_URL_DIRECT="postgresql://<user>:<pw>@<direct-endpoint>/<db>?sslmode=require"

# ─────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────
# Phase 5 (TLS) sets these. nginx terminates TLS in front of ORCA, so
# X-Forwarded-Proto reaches ORCA as "https" and secure cookies are
# valid.
PUBLIC_HTTP_PROTOCOL="https"
USE_SECURE_COOKIES="true"

# URL building: ORCA does not use PUBLIC_BASE_URL or a single public
# hostname env var. Each tenant's public host is the Organization
# `domain` in the database (e.g. pilot <org>.digitalbadges.scot). When
# Phase 4 adds nginx, ensure org records match your DNS. # TODO: align
# pilot org `domain` values with the real hostnames.
#
# Placeholder for operators mapping PoC to the production domain:
#   digitalbadges.scot  (wildcard tenant hostnames: *.digitalbadges.scot)

# Default-org fallback. Off in the PoC; flip on once a landing tenant
# is decided.
DEFAULT_ORG_ENABLED="false"
DEFAULT_ORG_DOMAIN=""

# ─────────────────────────────────────────────────────────────────────
# Email — deferred (see follow-on plan for Mailgun / SMTP in PoC)
# ─────────────────────────────────────────────────────────────────────
# # TODO: MAILGUN_* and send behaviour for production / staging.

# ─────────────────────────────────────────────────────────────────────
# Media - filesystem-backed via the orca-uploads named volume
# ─────────────────────────────────────────────────────────────────────
# isLocalDevFileMedia() in ORCA (src/lib/server/media.ts) is gated on
# PUBLIC_MEDIA_DOMAIN === "/media"; in this mode the S3 SDK is skipped.
# Uploads land in /app/dev-uploads in the container (orca-uploads volume).
PUBLIC_MEDIA_DOMAIN="/media"

# S3_* are unused in the filesystem media mode; listed for awareness if
# switching to S3 later.
S3_REGION=""
S3_BUCKET_NAME=""
S3_USE_LOCALSTACK="false"
S3_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─────────────────────────────────────────────────────────────────────
# Per-org secrets encryption (transaction-service-exchanges plan)
# ─────────────────────────────────────────────────────────────────────
# Required. 32 random bytes, base64-encoded. Generate with e.g.:
#   openssl rand -base64 32
# or:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ORG_CONFIG_ENCRYPTION_KEY=""

# ─────────────────────────────────────────────────────────────────────
# i18n (Locize) — leave blank in PoC; compiled paraglide messages used
# ─────────────────────────────────────────────────────────────────────
# # TODO: Locize project/API keys if live translation editing is required.
