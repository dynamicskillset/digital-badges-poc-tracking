# ORCA Environment Template
# Copy to .env.orca and fill in real values. The rendered .env.orca is
# gitignored alongside .env.transaction / .env.signing / .env.postgres.
#
# Transaction-service wiring note:
#   ORCA does NOT take the transaction service URL / tenantName / API
#   key as env vars. Those live on Organization.json per-org in the
#   database and are edited through ORCA's settings UI once the stack
#   is running. On this compose network, the per-org config values to
#   use are:
#     - url:         http://transaction-service:4004
#     - tenantName:  "default"  (or "testing")
#     - apiKey:      test-token-default  (or test-token-testing)
#   The tokens above come from .env.transaction. ORCA encrypts the key
#   at rest using ORG_CONFIG_ENCRYPTION_KEY below, so that is the only
#   .env.orca value that participates in transaction-service auth.

# ─────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────
# User / password / db must match POSTGRES_USER / POSTGRES_PASSWORD /
# POSTGRES_DB in .env.postgres. Schema orca_public is created by
# postgres/init/01-orca-db-and-schemas.sql - use ?schema=orca_public,
# not public.
DATABASE_SERVERLESS="false"
DATABASE_URL="postgresql://orcaadmin:REPLACE_WITH_A_STRONG_SECRET@postgres:5432/orca?schema=orca_public"
DATABASE_URL_DIRECT="postgresql://orcaadmin:REPLACE_WITH_A_STRONG_SECRET@postgres:5432/orca?schema=orca_public"

# Alternative: hosted Neon serverless. Comment the in-compose block
# above and uncomment below. DATABASE_URL_DIRECT must be the
# non-pooled Neon endpoint so prisma migrate deploy can connect.
# DATABASE_SERVERLESS="true"
# DATABASE_URL="postgresql://<user>:<pw>@<pooled-endpoint>/<db>?sslmode=require"
# DATABASE_URL_DIRECT="postgresql://<user>:<pw>@<direct-endpoint>/<db>?sslmode=require"

# ─────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────
# nginx terminates TLS in front of ORCA, so X-Forwarded-Proto reaches
# ORCA as "https" and secure cookies are valid.
PUBLIC_HTTP_PROTOCOL="https"
USE_SECURE_COOKIES="true"

# Default-org fallback. Off in the PoC; flip on once a landing tenant
# is decided. Each tenant's public host is the Organization `domain`
# in the database (e.g. <org>.digitalbadges.scot), not a single env
# var.
DEFAULT_ORG_ENABLED="false"
DEFAULT_ORG_DOMAIN=""

# ─────────────────────────────────────────────────────────────────────
# Email - SMTP via the in-compose "mail" service (self-hosted Postfix)
# ─────────────────────────────────────────────────────────────────────
# ORCA selects its mail transport by precedence (see
# orca/src/lib/email/sendEmail.ts):
#   1. MAILGUN_API_KEY set and != "none"  -> Mailgun
#   2. SMTP_HOST set                      -> SMTP (this block)
#   3. otherwise                          -> nodemailer jsonTransport
# For the PoC we use SMTP; leave Mailgun disabled via the "none"
# sentinel and point SMTP_* at the in-compose mail service.
MAILGUN_API_KEY="none"
MAILGUN_DOMAIN=""
MAILGUN_HOST=""

SMTP_HOST="mail"
SMTP_PORT="587"
SMTP_SECURE="false"
# SMTP_USER / SMTP_PASSWORD must match SMTP_USERNAME / SMTP_PASSWORD
# in .env.mail. CI renders both from the same two GH Actions secrets.
SMTP_USER=""
SMTP_PASSWORD=""

# ─────────────────────────────────────────────────────────────────────
# Media - filesystem-backed via the orca-uploads named volume
# ─────────────────────────────────────────────────────────────────────
# isLocalDevFileMedia() in ORCA (src/lib/server/media.ts) is gated on
# PUBLIC_MEDIA_DOMAIN === "/media"; in this mode the S3 SDK is skipped
# and uploads land in /app/dev-uploads (orca-uploads volume).
PUBLIC_MEDIA_DOMAIN="/media"

# S3_* are unused in the filesystem media mode; listed for awareness
# if switching to S3 later.
S3_REGION=""
S3_BUCKET_NAME=""
S3_USE_LOCALSTACK="false"
S3_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─────────────────────────────────────────────────────────────────────
# Per-org secrets encryption - used to encrypt Organization.json's
# transactionService.encryptedApiKey at rest. Required. 32 random
# bytes, base64-encoded. Generate with e.g.:
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────
ORG_CONFIG_ENCRYPTION_KEY=""

# ─────────────────────────────────────────────────────────────────────
# i18n (Locize) - leave blank in PoC; compiled paraglide messages used
# ─────────────────────────────────────────────────────────────────────
