# acme.sh + Mythic Beasts DNS-01 Environment Template
# Copy to .env.acme and fill in real values before issuing certs.
# .env.acme is listed explicitly in .gitignore (alongside the other
# .env.<service> files); the real file never lands in git.

# ─────────────────────────────────────────────────────────────────────
# Mythic Beasts DNS API credentials
# ─────────────────────────────────────────────────────────────────────
# Create in the Mythic Beasts control panel under
# "Domain names → Manage API keys". Restrict the key to writing ONLY
# the _acme-challenge TXT records on digitalbadges.scot so the secret
# in this file has minimum blast radius.
MYTHICBEASTS_USERNAME=""    # API key ID emitted by the control panel
MYTHICBEASTS_PASSWORD=""    # API secret emitted by the control panel

# ─────────────────────────────────────────────────────────────────────
# Let's Encrypt account email - used for expiry notifications.
# ─────────────────────────────────────────────────────────────────────
LE_EMAIL=""

# ─────────────────────────────────────────────────────────────────────
# SAN list for the wildcard cert. Edit if you ever add a new apex.
# ─────────────────────────────────────────────────────────────────────
ACME_DOMAIN_LIST="-d digitalbadges.scot -d *.digitalbadges.scot"
